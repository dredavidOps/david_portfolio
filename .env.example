# ==========================================
# Environment Variables — NOC Portfolio
# Copy this file to .env and fill in values
# ==========================================

# Public site URL (used for SEO, meta tags, sitemap)
VITE_SITE_URL=https://your-domain.vercel.app

# Contact form endpoint (e.g., Formspree, Getform, Netlify Forms)
VITE_CONTACT_FORM_URL=https://formspree.io/f/YOUR_FORM_ID

# Analytics tracking ID (e.g., Google Analytics, Plausible)
VITE_ANALYTICS_ID=G-XXXXXXXXXX

# Social profile URLs
VITE_LINKEDIN_URL=https://linkedin.com/in/davidyaotse
VITE_GITHUB_URL=https://github.com/dredavidOps

# Email for contact section
VITE_CONTACT_EMAIL=david.yaotse1@gmail.com

# CV / Resume download URL
VITE_CV_URL=/cv.pdf
